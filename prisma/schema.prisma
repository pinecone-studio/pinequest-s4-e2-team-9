// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}



model Teacher {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  school    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classrooms Classroom[]
  exams      Exam[]
}

model Classroom {
  id        String   @id @default(cuid())
  teacherId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher  Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students Student[]
  exams    Exam[]
}

model Student {
  id          String   @id @default(cuid())
  classroomId String
  displayName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classroom   Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  submissions Submission[]
}

model Exam {
  id               String   @id @default(cuid())
  teacherId        String
  classroomId      String
  title            String
  subject          String
  questionCount    Int
  pointPerQuestion Float    @default(1)
  totalScore       Float
  status           String   @default("needs_answer_key")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classroom   Classroom    @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  answerKeys  AnswerKey[]
  submissions Submission[]
}

model AnswerKey {
  id             String @id @default(cuid())
  examId         String
  questionNumber Int
  correctAnswer  String
  points         Float  @default(1)

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, questionNumber])
}

model Submission {
  id               String   @id @default(cuid())
  examId           String
  studentId        String
  imageUrl         String?
  status           String   @default("uploaded")
  aiConfidence     Float?
  score            Float    @default(0)
  totalScore        Float    @default(0)
  percentage       Float    @default(0)
  correctCount     Int      @default(0)
  wrongCount       Int      @default(0)
  blankCount       Int      @default(0)
  needsReview      Boolean  @default(false)
  teacherConfirmed Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  exam    Exam               @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers SubmissionAnswer[]
}

model SubmissionAnswer {
  id                   String  @id @default(cuid())
  submissionId          String
  questionNumber        Int
  detectedAnswer        String
  correctAnswer         String
  isCorrect             Boolean
  confidence            Float?
  pointsAwarded         Float
  teacherOverrideAnswer String?

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionNumber])
}